#!/usr/bin/env python3
"""
AZL Layer 5 - Amino Acids + Codons Ingest
I picked: The 20 amino acids + 64 DNA codons
Resume-safe. Appends correctly.
"""

from decimal import Decimal, getcontext
import hashlib
import json
from datetime import datetime, timezone
import os

getcontext().prec = 520
EPSILON = Decimal(1) / (Decimal(10) ** 500)

AMINO_ACIDS = [
    "Alanine","Arginine","Asparagine","Aspartic acid","Cysteine","Glutamine","Glutamic acid","Glycine",
    "Histidine","Isoleucine","Leucine","Lysine","Methionine","Phenylalanine","Proline","Serine",
    "Threonine","Tryptophan","Tyrosine","Valine"
]

CODONS = [ # 64 codons
    "UUU","UUC","UUA","UUG","UCU","UCC","UCA","UCG","UAU","UAC","UAA","UAG","UGU","UGC","UGA","UGG",
    "CUU","CUC","CUA","CUG","CCU","CCC","CCA","CCG","CAU","CAC","CAA","CAG","CGU","CGC","CGA","CGG",
    "AUU","AUC","AUA","AUG","ACU","ACC","ACA","ACG","AAU","AAC","AAA","AAG","AGU","AGC","AGA","AGG",
    "GUU","GUC","GUA","GUG","GCU","GCC","GCA","GCG","GAU","GAC","GAA","GAG","GGU","GGC","GGA","GGG"
]

class AZLLayer5:
    def __init__(self, registry_file="azl_registry_canon.jsonl"): # Use .jsonl for line-delimited
        self.registry_file = registry_file
        self.counter = 0
        self.load_state()
    
    def load_state(self):
        """Resumes from last counter regardless of format"""
        if os.path.exists(self.registry_file):
            with open(self.registry_file, 'r') as f:
                lines = [l for l in f if l.strip()]
                if lines:
                    try: # Try last line as JSON
                        last = json.loads(lines[-1])
                        self.counter = last.get("counter", len(lines))
                    except: # Fallback to line count
                        self.counter = len(lines)
            print(f"Resuming from address {self.counter:,}")
    
    def azl_mul(self, a, b):
        if a == 0: return Decimal(0)
        if b == 0: return a
        if a == EPSILON: return b + EPSILON
        return a * b
    
    def ingest(self, content, lens, category):
        self.counter += 1
        address = EPSILON * self.counter
        h = hashlib.sha256(f"{content}|{lens}|{category}".encode()).hexdigest()
        
        entry = {
            "azl_address": str(address),
            "counter": self.counter,
            "content": content,
            "content_hash": h,
            "lens": lens,
            "category": category,
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "verification_Nx0": self.azl_mul(address, Decimal(0)) == address
        }
        
        with open(self.registry_file, 'a') as f: # Always append
            f.write(json.dumps(entry) + "\n")
        
        if self.counter % 10 == 0:
            print(f" {self.counter:,} | {category} | {content}")
        return entry

if __name__ == "__main__":
    azl = AZLLayer5()
    
    print("=" * 60)
    print("AZL LAYER 5 - AMINO ACIDS + CODONS INGEST")
    print("I picked: 20 amino acids + 64 codons = 84 addresses")
    print("=" * 60)
    
    for aa in AMINO_ACIDS:
        azl.ingest(aa, "biology:standard:2026", "physical:amino_acid")
    
    for codon in CODONS:
        azl.ingest(codon, "biology:dna:standard", "physical:codon")
    
    print(f"\nTotal addresses now: {azl.counter:,}")
    print(f"Position 0→1: {EPSILON * azl.counter}")
    print("\n1×1=2. VOID FIRST. ORDER LOCKED.")
