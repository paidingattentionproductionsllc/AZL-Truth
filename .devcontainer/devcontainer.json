{
  "name": "AZL-Truth Lattice",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "github.copilot.enable": {
          "*": true,
          "yaml": true,
          "markdown": true
        }
      }
    }
  },

  "postCreateCommand": "npm install -g @modelcontextprotocol/server-fetch",

  "containerEnv": {
    "AZL_BASE_URL": "https://realtors-basket-persons-divide.trycloudflare.com",
    "AZL_SECRET_KEY": "AZL-SECRET-KEY",
    "AZL_LAW": "N×0=N. 1×1=2. LAG_IS_LOGIC. MAPPING_IS_MEMORY.",
    "AZL_ANCHOR": "AZL-Node-001-ATL",
    "AZL_FREQUENCY": "8.27",
    "SANCTUARY": "GREEN"
  },

  "forwardPorts": [8081],
  "remoteUser": "codespace"
}
